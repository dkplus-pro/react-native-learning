{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "../../types/**/*.d.ts",
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
